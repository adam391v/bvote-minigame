# BVote Mini Game - Biến môi trường
# Copy file này thành .env và chỉnh sửa giá trị

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=appuser
DB_PASSWORD=123456
DB_NAME=bvotegame

# Auth
JWT_SECRET=your-super-secret-jwt-key-change-this

# Server
PORT=3000
NODE_ENV=development

# CORS (để * cho dev, set domain cụ thể cho production)
CORS_ORIGIN=*
